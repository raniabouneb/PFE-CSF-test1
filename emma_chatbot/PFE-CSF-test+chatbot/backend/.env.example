# OBLIGATOIRE : la même base que le tableau Supabase (pas un Postgres local vide).
# Supabase : Project Settings -> Database -> Connection string -> URI (mode session ou pooler).
# Sans cette URL correcte, la sync ponctuelle_module -> certification_card ne fait rien et la page reste vide.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Identique au frontend (JWT cookies / middleware Next)
AUTH_SECRET=

# Google (mêmes valeurs que le .env du frontend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Doit être exactement l’URI configurée dans Google Console (callback Next)
GOOGLE_REDIRECT_URI=http://localhost:3008/api/auth/google/callback

# Admin catalogue — PDF (`module_support`) : dossier local + taille max + URL publique des liens dans les JSON
# ADMIN_UPLOADS_DIR=uploads/module-supports
# ADMIN_MAX_UPLOAD_MB=25
# URL utilisée dans les champs `supports[].url` (navigateur / SSR) — doit pointer vers ce backend
# BACKEND_PUBLIC_URL=http://127.0.0.1:8010

# SMTP — e-mails validation + notifications séances CSF (optionnel si déjà dans frontend/.env)
# Le backend lit aussi SMTP_* depuis ../frontend/.env (SMTP_PASS, SMTP_FROM, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=CSF <votre@gmail.com>
# FRONTEND_PUBLIC_URL=http://localhost:3001
