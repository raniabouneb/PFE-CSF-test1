# OBLIGATOIRE : la même base que le tableau Supabase (pas un Postgres local vide).
# Supabase : Project Settings -> Database -> Connection string -> URI (mode session ou pooler).
# Sans cette URL correcte, la sync ponctuelle_module -> certification_card ne fait rien et la page reste vide.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Identique au frontend (JWT cookies / middleware Next)
AUTH_SECRET=

# Google (mêmes valeurs que le .env du frontend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Doit être exactement l’URI configurée dans Google Console (callback Next)
GOOGLE_REDIRECT_URI=http://localhost:3008/api/auth/google/callback
